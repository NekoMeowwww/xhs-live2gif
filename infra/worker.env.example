# Tier A (browser worker host) — copy to /opt/xhs-worker/worker.env on the
# server and fill in. Loaded by infra/systemd/xhs-worker.service.
#
# Note: XHS_CDP_ENDPOINT is NOT set here — it's hardcoded in
# infra/systemd/xhs-worker.service's own Environment= line (must match the
# port xhs-chrome.service listens on, default http://127.0.0.1:19222).
# Change it in both places together if you ever need a different port.

# Redis lives on Tier B (see infra/docker-compose.api.yml). Point this at
# that host's private/internal address — restrict port 6379 via
# firewall/security group to Tier A's IP only, never expose it publicly.
XHS_REDIS_URL=redis://<tier-b-host>:6379

# S3-compatible object storage for GIF/zip results (already provisioned —
# plan section "结果存储").
XHS_S3_ENDPOINT=
XHS_S3_REGION=auto
XHS_S3_BUCKET=
XHS_S3_ACCESS_KEY_ID=
XHS_S3_SECRET_ACCESS_KEY=
# Set to "true" only if your S3-compatible provider requires path-style
# addressing (most self-hosted MinIO setups do; AWS S3 itself does not).
XHS_S3_FORCE_PATH_STYLE=false

# Alerting for session-health failures (see docs/runbook-relogin.md).
XHS_ALERT_WEBHOOK_URL=

# Known-good note used by the 15-minute health check smoke test — defaults
# to the note already proven end-to-end; override only if that note is
# ever deleted.
XHS_HEALTHCHECK_URL=http://xhslink.com/o/2E5XOr9DlHP
XHS_HEALTHCHECK_NOTE_ID=6a349af8000000000702c166
