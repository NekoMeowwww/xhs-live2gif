# Tier B (API container) — copy to infra/api.env and fill in.

# Allowed frontend origin(s) for CORS. Same-origin via nginx (recommended,
# see infra/nginx.conf) doesn't need this; set only if frontend is hosted
# elsewhere.
XHS_CORS_ORIGIN=

# Slack/webhook-style URL for "session unhealthy" alerts. Optional — also
# read by the Tier A worker (infra/worker.env.example), not just the API.
XHS_ALERT_WEBHOOK_URL=
